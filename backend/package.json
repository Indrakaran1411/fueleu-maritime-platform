{
  "name": "fueleu-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn src/infrastructure/server/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/infrastructure/server/index.js",
    "test": "jest --runInBand",
    "db:migrate": "ts-node src/infrastructure/db/migrate.ts",
    "db:seed": "ts-node src/infrastructure/db/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.0",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
